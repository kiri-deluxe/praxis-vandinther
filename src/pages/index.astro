---
import '../styles/global.css';

const DOCTOLIB_URL = "https://www.doctolib.de/allgemeinmedizin/krefeld/frank-van-dinther/booking/new-patient?specialityId=1286&source=profile";
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Praxis für Allgemeinmedizin Frank van Dinther · Krefeld</title>
  <meta name="description" content="Hausarztpraxis in Krefeld. Facharzt für Allgemeinmedizin. Termine bequem online über Doctolib buchen." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ─── Tokens ─────────────────────────────── */
    :root {
      --ff: 'Plus Jakarta Sans', system-ui, sans-serif;
      --c-bg:     #FFFFFF;
      --c-text:   #111111;
      --c-muted:  #888888;
      --c-subtle: #BBBBBB;
      --c-border: #E8E8E8;
      --c-doc:    #0071E3;
      --c-hero:   #0d1a10;
      --max-w:    1100px;
    }

    /* ─── Reset ──────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      font-family: var(--ff);
      font-weight: 300;
      background: var(--c-bg);
      color: var(--c-text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; height: auto; }
    button { background: none; border: none; cursor: pointer; font: inherit; }

    /* ─── Skip link ──────────────────────────── */
    .skip {
      position: absolute; top: -60px; left: 20px; z-index: 9999;
      background: #111; color: #fff; padding: 8px 16px; font-size: 13px;
      font-family: var(--ff);
    }
    .skip:focus { top: 10px; }

    /* ─── Wrap ───────────────────────────────── */
    .wrap { max-width: var(--max-w); margin: 0 auto; padding-left: 24px; padding-right: 24px; }

    /* ─── NAV ────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      height: 64px;
      display: flex;
      align-items: center;
      background: rgba(13, 26, 16, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 0.5px solid rgba(255,255,255,0.08);
      transition: background 350ms ease, border-color 350ms ease;
    }
    .nav.scrolled {
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom-color: var(--c-border);
    }
    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 24px;
      width: 100%;
      display: flex;
      align-items: center;
      gap: 32px;
    }
    .nav-logo {
      font-family: var(--ff);
      display: flex;
      flex-direction: column;
      gap: 1px;
      flex-shrink: 0;
      transition: color 350ms;
      line-height: 1.2;
    }
    .nav-logo-sub {
      font-weight: 300;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      transition: color 350ms;
    }
    .nav-logo-main {
      font-weight: 400;
      font-size: 14px;
      color: rgba(255,255,255,0.95);
      letter-spacing: 0.01em;
      transition: color 350ms;
    }
    .nav.scrolled .nav-logo-main { color: var(--c-text); }
    .nav.scrolled .nav-logo-sub { color: rgba(0,0,0,0.4); }

    .nav-links {
      display: none;
      list-style: none;
      gap: 28px;
      margin-left: auto;
    }
    @media (min-width: 768px) { .nav-links { display: flex; } }
    .nav-links a {
      font-family: var(--ff);
      font-weight: 400;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      transition: color 200ms;
    }
    .nav-links a:hover { color: rgba(255,255,255,0.9); }
    .nav.scrolled .nav-links a { color: rgba(0,0,0,0.45); }
    .nav.scrolled .nav-links a:hover { color: var(--c-text); }

    .btn-nav {
      font-family: var(--ff);
      font-weight: 400;
      font-size: 12px;
      letter-spacing: 0.03em;
      padding: 9px 18px;
      background: rgba(255,255,255,0.12);
      border: 0.5px solid rgba(255,255,255,0.3);
      color: rgba(255,255,255,0.9);
      border-radius: 6px;
      white-space: nowrap;
      cursor: pointer;
      transition: transform 200ms cubic-bezier(0.16,1,0.3,1),
                  background 200ms ease, border-color 200ms ease;
      display: none;
    }
    @media (min-width: 768px) { .btn-nav { display: block; } }
    .btn-nav:hover  { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.5); transform: scale(1.02); }
    .btn-nav:active { transform: scale(0.97); transition-duration: 100ms; }
    .nav.scrolled .btn-nav {
      background: #143731; border-color: #143731; color: #fff;
    }
    .nav.scrolled .btn-nav:hover { background: #0d2620; border-color: #0d2620; }

    .burger {
      margin-left: auto;
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: 8px;
    }
    @media (min-width: 768px) { .burger { display: none; } }
    .burger span {
      display: block; width: 22px; height: 1px;
      background: rgba(255,255,255,0.8);
      transition: transform 200ms, opacity 200ms, background 350ms;
    }
    .nav.scrolled .burger span { background: var(--c-text); }
    .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    /* ─── Mobile nav ─────────────────────────── */
    .mobile-nav {
      display: none;
      position: fixed;
      inset: 64px 0 0 0;
      z-index: 190;
      background: var(--c-hero);
      padding: 40px 24px;
      flex-direction: column;
      gap: 0;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      font-family: var(--ff);
      font-weight: 300;
      font-size: 22px;
      color: rgba(255,255,255,0.85);
      padding: 18px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      letter-spacing: -0.01em;
    }
    .mobile-nav-doc {
      margin-top: 28px;
      align-self: flex-start;
      font-family: var(--ff) !important;
      font-size: 13px !important;
      font-weight: 500 !important;
      padding: 12px 24px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 0;
    }

    /* ─── HERO ───────────────────────────────── */
    .hero {
      position: relative;
      width: 100%;
      height: 100svh;
      min-height: 600px;
      background: var(--c-hero);
      overflow: hidden;
    }

    #hero-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      pointer-events: none;
      padding: 0 clamp(24px, 4vw, 40px);
      z-index: 2;
    }

    /* Vignette overlay */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 38%, rgba(0,0,0,0.32) 100%);
      pointer-events: none;
      z-index: 1;
    }

    /* ── Headline block (top third) */
    .hero-top-block {
      padding-top: calc(60px + 80px); /* nav height + breathing room */
      max-width: var(--max-w);
      width: 100%;
      margin: 0 auto;
    }

    .hero-headline {
      font-family: var(--ff);
      font-weight: 300;
      font-size: clamp(64px, 7vw, 96px);
      line-height: 1;
      letter-spacing: -0.03em;
      color: #ffffff;
      margin: 0;
    }

    /* Word-by-word slide-up animation */
    .hw {
      display: inline-block;
      opacity: 0;
      transform: translateY(30px);
      animation: word-up 700ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--d, 0ms);
    }
    @keyframes word-up {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Bottom row (buttons + sub) */
    .hero-bottom-block {
      max-width: var(--max-w);
      width: 100%;
      margin: 0 auto;
      padding-bottom: 48px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }
    @media (min-width: 640px) {
      .hero-bottom-block {
        flex-direction: row;
        align-items: flex-end;
        justify-content: space-between;
      }
    }

    .hero-sub {
      font-family: var(--ff);
      font-weight: 300;
      font-size: 13px;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
      max-width: 220px;
      opacity: 0;
      animation: sub-fade 600ms ease forwards;
      animation-delay: 500ms;
    }
    @keyframes sub-fade {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: none; }
    }

    .hero-btn-row {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      flex-shrink: 0;
      opacity: 0;
      animation: sub-fade 600ms ease forwards;
      animation-delay: 560ms;
    }
    @media (min-width: 640px) { .hero-btn-row { align-items: flex-end; } }

    .hero-btns {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      pointer-events: auto;
    }

    .hero-badge {
      font-family: var(--ff);
      font-weight: 400;
      font-size: 11px;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.35);
      text-transform: uppercase;
    }
    .hero-badge::before {
      content: '● ';
      color: #5adf7a;
      font-size: 8px;
      vertical-align: middle;
      margin-right: 4px;
    }

    /* ─── BUTTON SYSTEM ──────────────────────── */
    /* Primary — white on dark / dark on light */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 13px 28px;
      border-radius: 6px;
      font-family: var(--ff); font-weight: 400; font-size: 13px;
      letter-spacing: 0.03em;
      background: #ffffff; color: #111111;
      border: none; cursor: pointer;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  background 200ms cubic-bezier(0.16, 1, 0.3, 1);
      white-space: nowrap;
      text-decoration: none;
    }
    .btn-primary:hover  { transform: scale(1.02); background: #ececec; }
    .btn-primary:active { transform: scale(0.97); transition-duration: 100ms; }

    /* Primary inverted (dark bg, for light-section contexts) */
    .btn-primary-dark {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 13px 28px;
      border-radius: 6px;
      font-family: var(--ff); font-weight: 400; font-size: 13px;
      letter-spacing: 0.03em;
      background: #111111; color: #ffffff;
      border: none; cursor: pointer;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  background 200ms cubic-bezier(0.16, 1, 0.3, 1);
      white-space: nowrap;
      text-decoration: none;
    }
    .btn-primary-dark:hover  { transform: scale(1.02); background: #2a2a2a; }
    .btn-primary-dark:active { transform: scale(0.97); transition-duration: 100ms; }

    /* Ghost */
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 13px 28px;
      border-radius: 6px;
      font-family: var(--ff); font-weight: 400; font-size: 13px;
      letter-spacing: 0.03em;
      background: transparent;
      border: 0.5px solid rgba(255,255,255,0.35);
      color: rgba(255,255,255,0.75);
      cursor: pointer;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  border-color 200ms ease,
                  background 200ms ease;
      white-space: nowrap;
      text-decoration: none;
    }
    .btn-ghost:hover  {
      border-color: rgba(255,255,255,0.85);
      background: rgba(255,255,255,0.07);
      transform: scale(1.02);
    }
    .btn-ghost:active { transform: scale(0.97); transition-duration: 100ms; }

    /* ─── CARDS SECTION ─────────────────────── */
    .cards-section {
      background: #f5f5f0;
      padding: clamp(64px, 8vw, 96px) 0;
    }
    .cards-headline {
      font-family: var(--ff);
      font-weight: 300;
      font-size: clamp(36px, 6vw, 60px);
      letter-spacing: -0.03em;
      line-height: 1.0;
      color: var(--c-text);
      margin-bottom: 48px;
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 700ms ease, transform 700ms ease;
    }
    .cards-headline.visible { opacity: 1; transform: none; }

    .cards-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: rgba(0,0,0,0.08);
    }
    @media (min-width: 640px) {
      .cards-grid { grid-template-columns: repeat(3, 1fr); }
    }

    .card {
      padding: 28px;
      display: flex;
      flex-direction: column;
      /* content-driven height — no min-height */
      transition: transform 250ms cubic-bezier(0.16,1,0.3,1),
                  background 250ms ease,
                  border 250ms ease;
    }
    .card--lime  { background: #CEFF8C; color: #143731; }
    .card--dark  { background: #143731; color: #CEFF8C; }
    .card--sand  { background: #E8E0D4; color: #143731; }

    /* Hover — desktop only, no shadows */
    @media (min-width: 640px) {
      .card:hover               { transform: translateY(-2px); }
      .card--lime:hover         { background: #D4FF9A; }
      .card--dark:hover         { background: #1a4a3d;
                                  border: 0.5px solid rgba(206,255,140,0.3); }
      .card--sand:hover         { background: #F0E8DC; }
    }

    /* Icon: 64×64, stroke only, inherits card text color */
    .card-icon {
      width: 64px;
      height: 64px;
      flex-shrink: 0;
      margin-bottom: 24px;
      color: inherit;
    }

    /* Body: holds title + text, grows */
    .card-body { display: flex; flex-direction: column; flex: 1; }

    /* Title: min-height ensures alignment across all 3 cards */
    .card-title {
      font-family: var(--ff);
      font-weight: 500;
      font-size: 20px;
      letter-spacing: -0.02em;
      line-height: 1.15;
      color: inherit;
      margin: 0 0 12px 0;
      min-height: 52px;
      display: flex;
      align-items: flex-end;
    }

    .card-text {
      font-family: var(--ff);
      font-weight: 300;
      font-size: 13px;
      line-height: 1.7;
    }
    .card--lime  .card-text { color: rgba(20,55,49,0.65); }
    .card--dark  .card-text { color: rgba(206,255,140,0.55); }
    .card--sand  .card-text { color: rgba(20,55,49,0.65); }

    /* Mobile: row layout — icon left, text right */
    @media (max-width: 639px) {
      .card { flex-direction: row; align-items: flex-start; gap: 16px; }
      .card-icon { width: 48px; height: 48px; margin-bottom: 0; margin-top: 2px; flex-shrink: 0; }
      .card-title { min-height: unset; align-items: flex-start; }
    }

    /* ─── TICKER ─────────────────────────────── */
    .ticker {
      border-top: 0.5px solid var(--c-border);
      border-bottom: 0.5px solid var(--c-border);
      overflow: hidden;
      padding: 16px 0;
      background: var(--c-bg);
    }
    .ticker-track {
      display: inline-flex;
      white-space: nowrap;
      animation: ticker-scroll 45s linear infinite;
    }
    .ticker-track:hover { animation-play-state: paused; }
    .ticker-item {
      font-family: var(--ff);
      font-weight: 300;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--c-subtle);
      padding: 0 36px;
    }
    .ticker-sep { color: var(--c-border); }

    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── Section base ───────────────────────── */
    .section {
      border-top: 0.5px solid var(--c-border);
      padding-top: clamp(48px, 8vw, 88px);
      padding-bottom: clamp(48px, 8vw, 88px);
    }

    /* ─── Section label ──────────────────────── */
    .label {
      font-family: var(--ff);
      font-weight: 400;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--c-muted);
      margin-bottom: 28px;
    }

    /* ─── Section headline ───────────────────── */
    .headline {
      font-family: var(--ff);
      font-weight: 300;
      font-size: clamp(2rem, 5vw, 3.25rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--c-text);
      margin-bottom: 40px;
    }

    /* ─── Buttons ────────────────────────────── */
    .btn-dark {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--c-text); color: #fff;
      font-family: var(--ff); font-weight: 500; font-size: 13px;
      letter-spacing: 0.02em; padding: 13px 24px; border-radius: 0;
      white-space: nowrap; transition: opacity 180ms;
    }
    .btn-dark:hover { opacity: 0.75; }

    .btn-doc {
      display: inline-flex; align-items: center; gap: 8px;
      background: #143731; color: #fff; border: none;
      font-family: var(--ff); font-weight: 400; font-size: 13px;
      letter-spacing: 0.02em; padding: 13px 28px; border-radius: 6px;
      white-space: nowrap; cursor: pointer; text-decoration: none;
      transition: transform 200ms ease, background 200ms ease;
    }
    .btn-doc:hover  { background: #0d2620; transform: scale(1.02); }
    .btn-doc:active { transform: scale(0.97); transition-duration: 100ms; }

    /* ─── HOURS SECTION ─────────────────────── */
    #oeffnungszeiten.section {
      background: #EAEBE6;
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .hours-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    @media (min-width: 640px) {
      .hours-cards { grid-template-columns: repeat(3, 1fr); }
    }

    .hours-card {
      background: #ffffff;
      border-radius: 12px;
      padding: 32px 28px;
    }

    .live-indicator {
      display: flex; align-items: center; gap: 7px;
      margin-bottom: 20px;
    }
    .live-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #ccc; flex-shrink: 0;
    }
    .live-label {
      font-family: var(--ff); font-weight: 300;
      font-size: 11px; color: #999; letter-spacing: 0.02em;
    }

    .hours-card-title {
      font-family: var(--ff); font-weight: 500;
      font-size: 20px; color: #111;
      letter-spacing: -0.01em; margin-bottom: 18px;
    }

    .hours-card-rows { display: flex; flex-direction: column; }
    .hours-card-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: 7px 0; border-top: 0.5px solid #EBEBEB; gap: 8px;
    }
    .hours-card-day {
      font-family: var(--ff); font-weight: 300;
      font-size: 14px; color: #888; white-space: nowrap;
    }
    .hours-card-time {
      font-family: var(--ff); font-weight: 300;
      font-size: 15px; color: #444;
      white-space: nowrap; font-variant-numeric: tabular-nums;
    }

    .hours-card-note {
      font-family: var(--ff); font-weight: 300;
      font-size: 12px; color: #aaa; margin-top: 16px;
    }
    .hours-card-link {
      display: inline-block;
      font-family: var(--ff); font-weight: 400;
      font-size: 13px; color: #143731;
      margin-top: 10px; text-decoration: none;
      border-bottom: 0.5px solid currentColor; padding-bottom: 1px;
      transition: opacity 150ms;
    }
    .hours-card-link:hover { opacity: 0.65; }

    /* ─── SCHLIEßZEITEN ──────────────────────── */
    .schliesszeiten {
      margin-top: 48px; padding-top: 28px;
      border-top: 0.5px solid rgba(0,0,0,0.12);
    }
    .schliesszeiten-label {
      font-family: var(--ff); font-weight: 400;
      font-size: 10px; letter-spacing: 0.1em;
      text-transform: uppercase; color: #888; margin-bottom: 14px;
    }
    .schliesszeiten-list { list-style: none; }
    .schliesszeiten-item {
      display: flex; gap: 20px; align-items: baseline;
      font-family: var(--ff); font-weight: 300;
      font-size: 14px; color: #666;
      padding: 9px 0;
      border-bottom: 0.5px solid rgba(0,0,0,0.07);
    }
    .schliesszeiten-item:first-child { border-top: 0.5px solid rgba(0,0,0,0.07); }
    .schliesszeiten-item-date { flex: 1; }
    .schliesszeiten-item-type { color: #aaa; font-size: 13px; }

    /* ─── NOTFALL buttons ────────────────────── */
    .notfall-clean {
      margin-top: 36px; padding-top: 28px;
      border-top: 0.5px solid rgba(0,0,0,0.12);
    }
    .notfall-clean-intro {
      font-family: var(--ff); font-weight: 400;
      font-size: 10px; letter-spacing: 0.1em;
      text-transform: uppercase; color: #888; margin-bottom: 14px;
    }
    .notfall-btns { display: flex; flex-wrap: wrap; gap: 10px; }
    .notfall-btn {
      display: inline-flex; align-items: center; gap: 10px;
      background: #f5f5f0;
      border: 0.5px solid #E8E5E0;
      border-radius: 10px;
      padding: 14px 24px;
      cursor: pointer; text-decoration: none;
      transition: background 200ms ease, border-color 200ms ease;
    }
    .notfall-btn:hover { background: #EEEAE7; border-color: #CEFF8C; }
    .notfall-btn-icon { flex-shrink: 0; color: #143731; }
    .notfall-btn-body { display: flex; flex-direction: column; gap: 2px; }
    .notfall-btn-number {
      font-family: var(--ff); font-weight: 500;
      font-size: 16px; color: #111; line-height: 1;
    }
    .notfall-btn-label {
      font-family: var(--ff); font-weight: 300;
      font-size: 11px; color: #888;
    }

    /* ─── ABOUT ──────────────────────────────── */
    #arzt { border-top: 0.5px solid var(--c-border); }

    /* ─── ÜBER UNS ─────────────────────────── */
    .about-section { background: #ffffff; padding: 80px 40px; }
    @media (max-width: 639px) { .about-section { padding: 48px 24px; } }
    .about-inner { max-width: var(--max-w); margin: 0 auto; }

    .about-label {
      font-family: var(--ff); font-weight: 400;
      font-size: 10px; letter-spacing: 0.12em;
      text-transform: uppercase; color: #888; margin-bottom: 16px;
    }
    .about-headline {
      font-family: var(--ff); font-weight: 300;
      font-size: clamp(32px, 4vw, 48px); color: #111;
      letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 16px;
    }
    .about-subtext {
      font-family: var(--ff); font-weight: 300;
      font-size: 16px; color: #666; line-height: 1.75;
      max-width: 560px; margin: 0;
    }

    /* Team grid */
    .about-team-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px;
      margin-top: 60px;
    }
    .about-member-photo-wrap {
      width: 100%; aspect-ratio: 3/4; border-radius: 12px;
      overflow: hidden; margin-bottom: 16px; background: #f5f5f0;
    }
    .about-member-photo {
      width: 100%; height: 100%; object-fit: cover;
      object-position: top center; display: block;
    }
    .about-member-info { display: contents; }
    .about-member-name {
      font-family: var(--ff); font-weight: 500;
      font-size: 16px; color: #111; margin-bottom: 4px;
    }
    .about-member-title {
      font-family: var(--ff); font-weight: 300;
      font-size: 13px; color: #888;
    }
    @media (max-width: 767px) {
      .about-team-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    }
    @media (max-width: 639px) {
      .about-team-grid { grid-template-columns: 1fr; gap: 0; margin-top: 40px; }
      .about-member {
        display: flex; flex-direction: row; align-items: center; gap: 16px;
        padding: 16px 0; border-bottom: 0.5px solid #E8E5E0;
      }
      .about-member:last-child { border-bottom: none; }
      .about-member-photo-wrap {
        width: 80px; height: 80px; aspect-ratio: 1;
        border-radius: 50%; flex-shrink: 0; margin-bottom: 0;
      }
      .about-member-info { display: flex; flex-direction: column; gap: 2px; }
      .about-member-name { font-size: 15px; margin-bottom: 0; }
    }

    /* Stats bar */
    .about-stats {
      margin-top: 64px; background: #143731;
      border-radius: 16px; padding: 32px 40px;
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 0; align-items: start;
    }
    .about-stat {
      text-align: center;
      padding: 0 28px;
      border-right: 0.5px solid rgba(255,255,255,0.1);
    }
    .about-stat:first-child { padding-left: 0; }
    .about-stat:last-child { border-right: none; padding-right: 0; }
    .about-stat-num {
      font-family: var(--ff); font-weight: 600;
      font-size: 36px; color: #CEFF8C; line-height: 1; letter-spacing: -0.02em;
    }
    .about-stat-lbl {
      font-family: var(--ff); font-weight: 300;
      font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.5; margin-top: 6px;
    }
    @media (max-width: 639px) {
      .about-stats {
        grid-template-columns: 1fr;
        padding: 16px 24px;
        gap: 0;
      }
      .about-stat {
        display: flex; flex-direction: row; align-items: center; gap: 16px;
        text-align: left; padding: 16px 0;
        border-right: none;
        border-bottom: 0.5px solid rgba(255,255,255,0.1);
      }
      .about-stat:last-child { border-bottom: none; }
      .about-stat-num { min-width: 72px; flex-shrink: 0; text-align: left; font-size: 28px; line-height: 1; }
      .about-stat-lbl { font-size: 13px; line-height: 1.4; margin-top: 0; padding-top: 0; flex: 1; }
    }

    /* ─── SERVICES / ACCORDION ───────────────── */
    .accordion-item { border-bottom: 0.5px solid #E8E5E0; }
    .accordion-item:last-child { border-bottom: none; }

    .accordion-trigger {
      width: 100%; display: flex;
      justify-content: space-between; align-items: center;
      padding: 24px 0; text-align: left; gap: 16px;
    }
    .accordion-trigger-name {
      font-family: var(--ff); font-weight: 400;
      font-size: 20px; color: #111;
      display: inline;
      transition: background 200ms ease, padding 150ms ease, border-radius 150ms ease;
      border-radius: 4px;
    }
    .accordion-icon {
      font-family: var(--ff); font-weight: 300;
      font-size: 20px; color: var(--c-muted);
      flex-shrink: 0; line-height: 1;
      transition: transform 200ms cubic-bezier(0.16,1,0.3,1), color 200ms ease;
    }

    /* Open state — title highlight + icon */
    .accordion-trigger[aria-expanded="true"] .accordion-trigger-name {
      background: #CEFF8C;
      padding: 2px 6px;
    }
    .accordion-trigger[aria-expanded="true"] .accordion-icon {
      transform: rotate(45deg);
      color: #143731;
    }

    /* Body */
    .accordion-body {
      display: grid; grid-template-rows: 0fr;
      transition: grid-template-rows 280ms ease;
    }
    .accordion-body.open { grid-template-rows: 1fr; }
    .accordion-body-inner { overflow: hidden; }

    /* List */
    .accordion-list {
      list-style: none;
      padding: 8px 0 32px 20px;
      display: flex; flex-direction: column; gap: 6px;
    }
    .accordion-list li {
      font-family: var(--ff); font-weight: 300;
      font-size: 17px; color: #444;
      padding: 4px 0; line-height: 1.9;
      position: relative; padding-left: 20px;
    }
    .accordion-list li::before {
      content: '·'; position: absolute; left: 0;
      color: #143731; font-size: 20px; font-weight: 600;
      line-height: 1.5; font-family: var(--ff);
    }

    /* Hover — desktop only, title text only */
    @media (hover: hover) {
      .accordion-trigger:not([aria-expanded="true"]):hover .accordion-trigger-name {
        background: #CEFF8C;
        padding: 2px 6px;
        cursor: pointer;
      }
    }

    /* ─── STUDENTS ───────────────────────────── */
    .students-wrap {
      margin: 0 40px;
    }
    .students-card {
      background: #143731; border-radius: 24px; overflow: hidden;
      padding: 64px 48px;
    }
    .students-label {
      font-family: var(--ff); font-weight: 300;
      font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      color: #CEFF8C; margin-bottom: 20px;
    }
    .students-headline {
      font-family: var(--ff); font-weight: 300;
      font-size: 44px; color: #ffffff;
      letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 16px;
    }
    .studierende-inner {
      display: grid; grid-template-columns: 1fr; gap: 40px;
    }
    @media (min-width: 768px) {
      .studierende-inner { grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
    }
    .students-subtext {
      font-family: var(--ff); font-weight: 300;
      font-size: 16px; color: rgba(255,255,255,0.6);
      line-height: 1.75; max-width: 560px; margin-bottom: 48px;
    }
    .students-docs-label {
      font-family: var(--ff); font-weight: 400;
      font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
      color: #CEFF8C; margin-bottom: 20px;
    }
    .students-doc-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; margin-bottom: 8px;
      background: rgba(255,255,255,0.06);
      border: 0.5px solid rgba(255,255,255,0.1);
      border-radius: 10px; cursor: pointer; text-decoration: none;
      transition: background 200ms ease, border-color 200ms ease;
    }
    .students-doc-item:hover {
      background: rgba(206,255,140,0.1);
      border-color: rgba(206,255,140,0.3);
    }
    .students-doc-item:hover .students-doc-arrow { color: #CEFF8C; }
    .students-doc-left {
      display: flex; align-items: center; gap: 12px;
    }
    .students-doc-icon { color: rgba(255,255,255,0.5); flex-shrink: 0; }
    .students-doc-meta { display: flex; flex-direction: column; gap: 2px; }
    .students-doc-name {
      font-family: var(--ff); font-weight: 400;
      font-size: 14px; color: #ffffff;
    }
    .students-doc-tag {
      font-family: var(--ff); font-weight: 300;
      font-size: 12px; color: rgba(255,255,255,0.4);
    }
    .students-doc-arrow { color: rgba(255,255,255,0.4); flex-shrink: 0; transition: color 200ms ease; }
    .students-cta {
      margin-top: 40px; padding-top: 32px;
      border-top: 0.5px solid rgba(255,255,255,0.1);
      display: flex; align-items: center;
      justify-content: space-between; flex-wrap: wrap; gap: 16px;
    }
    .students-cta-text {
      font-family: var(--ff); font-weight: 300;
      font-size: 15px; color: rgba(255,255,255,0.6);
    }
    .students-cta-btn {
      display: inline-flex; align-items: center;
      background: transparent; color: #ffffff;
      border: 0.5px solid rgba(255,255,255,0.4);
      padding: 12px 24px; border-radius: 6px;
      font-family: var(--ff); font-weight: 400; font-size: 13px;
      text-decoration: none; white-space: nowrap;
      transition: border-color 200ms ease, color 200ms ease;
    }
    .students-cta-btn:hover { border-color: #CEFF8C; color: #CEFF8C; }
    @media (max-width: 639px) {
      .students-wrap { margin: 0 16px; }
      .students-card { border-radius: 16px; padding: 32px 24px; }
      .students-headline { font-size: 30px; }
      .students-doc-item { padding: 12px 16px; }
      .students-cta { flex-direction: column; align-items: flex-start; }
    }

    /* ─── CONTACT ────────────────────────────── */
    .contact-section { background: #f5f5f0; padding: 80px 40px; }
    @media (max-width: 639px) { .contact-section { padding: 48px 24px; } }
    .contact-inner { max-width: var(--max-w); margin: 0 auto; }
    .contact-label {
      font-family: var(--ff); font-weight: 400;
      font-size: 10px; letter-spacing: 0.12em;
      text-transform: uppercase; color: #888; margin-bottom: 16px;
    }
    .contact-headline {
      font-family: var(--ff); font-weight: 300;
      font-size: clamp(32px, 4vw, 48px); color: #111;
      letter-spacing: -0.02em; margin-bottom: 48px;
    }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 32px; align-items: stretch;
    }
    @media (max-width: 767px) { .contact-grid { grid-template-columns: 1fr; } }

    /* Left card */
    .contact-card {
      background: #ffffff; border-radius: 16px;
      padding: 40px; display: flex; flex-direction: column; gap: 32px;
    }
    .contact-praxis-primary {
      font-family: var(--ff); font-weight: 500; font-size: 18px; color: #111;
    }
    .contact-praxis-secondary {
      font-family: var(--ff); font-weight: 300; font-size: 18px; color: #666;
      margin-top: 2px; margin-bottom: 20px;
    }
    .contact-addr-text {
      font-family: var(--ff); font-weight: 300;
      font-size: 15px; color: #444; line-height: 1.8;
    }
    .contact-row {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; color: #111;
      font-family: var(--ff); font-weight: 400; font-size: 15px;
      transition: color 150ms ease;
    }
    .contact-row-fax { color: #888; cursor: default; }
    .contact-row-email { color: #143731; }
    .contact-row:not(.contact-row-fax):hover { color: #143731; text-decoration: underline; }
    .contact-row-icon { color: #143731; flex-shrink: 0; }
    .contact-row-fax .contact-row-icon { color: #bbb; }
    .contact-divider { border: none; border-top: 0.5px solid #E8E5E0; margin: 0; }
    .contact-doctolib-label {
      font-family: var(--ff); font-weight: 300; font-size: 13px; color: #888;
      margin-bottom: 12px;
    }
    .contact-doctolib-btn {
      display: block; width: 100%; text-align: center;
      background: #143731; color: #ffffff; border: none;
      font-family: var(--ff); font-weight: 500; font-size: 14px;
      padding: 14px; border-radius: 8px; text-decoration: none;
      transition: background 200ms ease;
    }
    .contact-doctolib-btn:hover { background: #0d2620; }

    /* Right card — map */
    .contact-map-card {
      background: #ffffff; border-radius: 16px; overflow: hidden;
      display: flex; flex-direction: column;
    }
    .contact-map-card iframe {
      flex: 1; width: 100%; min-height: 400px; border: none; display: block;
    }
    @media (max-width: 767px) { .contact-map-card iframe { min-height: 280px; } }
    .contact-map-footer {
      display: block; padding: 10px 16px; background: #ffffff;
      font-family: var(--ff); font-weight: 300; font-size: 12px; color: #888;
      text-decoration: none; transition: color 150ms ease; flex-shrink: 0;
    }
    .contact-map-footer:hover { color: #143731; }

    /* ÖPNV bar */
    .contact-oepnv {
      margin-top: 24px; background: #143731; border-radius: 12px;
      padding: 20px 28px; display: flex; align-items: center;
      gap: 20px; flex-wrap: wrap;
    }
    .contact-oepnv-icon { color: #CEFF8C; flex-shrink: 0; }
    .contact-oepnv-text { flex: 1; min-width: 0; }
    .contact-oepnv-title {
      font-family: var(--ff); font-weight: 500; font-size: 14px; color: #CEFF8C;
    }
    .contact-oepnv-detail {
      font-family: var(--ff); font-weight: 300; font-size: 13px;
      color: rgba(255,255,255,0.6); margin-top: 2px;
    }
    .contact-oepnv-link {
      font-family: var(--ff); font-weight: 400; font-size: 13px;
      color: #CEFF8C; text-decoration: none; white-space: nowrap; margin-left: auto;
    }
    .contact-oepnv-link:hover { text-decoration: underline; }
    @media (max-width: 767px) {
      .contact-oepnv { flex-direction: column; align-items: flex-start; }
      .contact-oepnv-link { margin-left: 0; }
    }

    /* ─── FOOTER ─────────────────────────────── */
    footer {
      border-top: 0.5px solid var(--c-border);
      padding: 32px 24px;
    }
    .footer-inner {
      max-width: var(--max-w); margin: 0 auto;
      display: flex; flex-wrap: wrap;
      justify-content: space-between; align-items: center; gap: 12px;
    }
    .footer-copy {
      font-family: var(--ff); font-weight: 300;
      font-size: 12px; color: var(--c-muted);
    }
    .footer-links { display: flex; gap: 24px; list-style: none; }
    .footer-links a {
      font-family: var(--ff); font-weight: 300;
      font-size: 12px; color: var(--c-muted); transition: color 150ms;
    }
    .footer-links a:hover { color: var(--c-text); }

    /* ─── Focus & motion ─────────────────────── */
    *:focus-visible { outline: 1.5px solid var(--c-text); outline-offset: 3px; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>

<body>
  <a href="#main" class="skip">Zum Inhalt springen</a>

  <!-- ── NAV ─────────────────────────────────── -->
  <nav class="nav" id="nav" aria-label="Hauptnavigation">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="Praxis van Dinther — Startseite">
        <span class="nav-logo-sub">Praxis für Allgemeinmedizin</span>
        <span class="nav-logo-main">Frank van Dinther</span>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="#oeffnungszeiten">Sprechzeiten</a></li>
        <li><a href="#arzt">Über uns</a></li>
        <li><a href="#leistungen">Leistungen</a></li>
        <li><a href="#kontakt">Kontakt</a></li>
      </ul>
      <a href={DOCTOLIB_URL} target="_blank" rel="noopener noreferrer" class="btn-nav">
        Termin buchen
      </a>
      <button class="burger" id="burger" aria-expanded="false"
              aria-controls="mobile-nav" aria-label="Menü öffnen">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav" role="navigation" aria-label="Mobile Navigation">
    <a href="#oeffnungszeiten">Sprechzeiten</a>
    <a href="#arzt">Über uns</a>
    <a href="#leistungen">Leistungen</a>
    <a href="#studierende">Für Studierende</a>
    <a href="#kontakt">Kontakt</a>
    <a href={DOCTOLIB_URL} target="_blank" rel="noopener noreferrer" class="mobile-nav-doc">
      Termin bei Doctolib
    </a>
  </div>

  <main id="main">

    <!-- ── HERO ─────────────────────────────── -->
    <section class="hero" aria-label="Willkommen">
      <canvas id="hero-canvas" aria-hidden="true"></canvas>

      <div class="hero-content">

        <!-- Headline: top third -->
        <div class="hero-top-block">
          <h1 class="hero-headline" aria-label="Ihre Gesundheit in guten Händen.">
            <span class="hw" style="--d:0ms">Ihre</span>
            <span class="hw" style="--d:80ms"> Gesundheit</span><br aria-hidden="true">
            <span class="hw" style="--d:160ms">in</span>
            <span class="hw" style="--d:240ms"> guten</span>
            <span class="hw" style="--d:320ms"> Händen.</span>
          </h1>
        </div>

        <!-- Bottom row: sub + buttons -->
        <div class="hero-bottom-block">
          <p class="hero-sub">
            Allgemeinmedizin in Krefeld-Elfrath<br>
            für die ganze Familie, mit Zeit für Ihre Fragen.
          </p>
          <div class="hero-btn-row">
            <div class="hero-btns">
              <a href={DOCTOLIB_URL} target="_blank" rel="noopener noreferrer"
                 class="btn-primary" aria-label="Termin vereinbaren via Doctolib">
                Termin vereinbaren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <a href="#oeffnungszeiten" class="btn-ghost">
                Öffnungszeiten
              </a>
            </div>
            <span class="hero-badge">Heute geöffnet ab 08:30</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ── CARDS SECTION ─────────────────────── -->
    <section class="cards-section" aria-labelledby="cards-heading">
      <div class="wrap">
        <h2 class="cards-headline" id="cards-heading">
          Was uns<br>ausmacht.
        </h2>

        <div class="cards-grid">

          <!-- Card 1: Persönlich (lime) -->
          <div class="card card--lime feature-card">
            <svg class="card-icon" width="64" height="64" viewBox="0 0 64 64" fill="none"
                 stroke="currentColor" stroke-width="1.2" stroke-linecap="round"
                 aria-hidden="true">
              <circle cx="24" cy="32" r="16"/>
              <circle cx="40" cy="32" r="16"/>
            </svg>
            <div class="card-body">
              <h3 class="card-title">Persönlich</h3>
              <p class="card-text">Jeder Patient ist anders — und verdient echte Aufmerksamkeit.
                Wir hören zu, erklären und nehmen uns Zeit für Ihre Fragen.
                Medizin, die den Menschen sieht.</p>
            </div>
          </div>

          <!-- Card 2: Vorsorge (dark) -->
          <div class="card card--dark feature-card">
            <svg class="card-icon" width="64" height="64" viewBox="0 0 64 64" fill="none"
                 stroke="currentColor" stroke-width="1.2" stroke-linecap="round"
                 aria-hidden="true">
              <path d="M32 12 L32 52 M12 32 L52 32"/>
              <circle cx="32" cy="32" r="20"/>
            </svg>
            <div class="card-body">
              <h3 class="card-title">Vorsorge</h3>
              <p class="card-text">Früh erkennen ist besser als spät behandeln.
                Wir begleiten Sie mit regelmäßigen Checks und
                modernen Vorsorgeuntersuchungen für jedes Lebensalter.</p>
            </div>
          </div>

          <!-- Card 3: Hausbesuche (light) -->
          <div class="card card--sand feature-card">
            <svg class="card-icon" width="64" height="64" viewBox="0 0 64 64" fill="none"
                 stroke="currentColor" stroke-width="1.2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
              <path d="M12 30 L32 12 L52 30 L52 52 L12 52 Z"/>
              <path d="M24 52 L24 38 L40 38 L40 52"/>
            </svg>
            <div class="card-body">
              <h3 class="card-title">Hausbesuche</h3>
              <p class="card-text">Wenn der Weg in die Praxis nicht möglich ist,
                kommen wir zu Ihnen — schnell, unkompliziert und vertrauensvoll.
                Weil Ihre Gesundheit keine Wartezeit kennt.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── TICKER ────────────────────────────── -->
    <div class="ticker" aria-hidden="true">
      <div class="ticker-track">
        <span class="ticker-item">Allgemeinmedizin</span>
        <span class="ticker-item ticker-sep">·</span>
        <span class="ticker-item">Familienpraxis</span>
        <span class="ticker-item ticker-sep">·</span>
