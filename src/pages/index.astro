                 class="contact-doctolib-btn">
                Jetzt Termin vereinbaren
              </a>
            </div>
          </div>

          <!-- Right: Map -->
          <div class="contact-map-card">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=6.5620%2C51.3480%2C6.5920%2C51.3640&layer=mapnik&marker=51.3559%2C6.5770"
              loading="lazy"
              title="Praxis van Dinther auf der Karte"
              aria-label="Karte: Neukirchener Straße 5, 47829 Krefeld"
            ></iframe>
            <a href="https://maps.google.com/?q=Neukirchener+Straße+5,+47829+Krefeld"
               target="_blank" rel="noopener noreferrer" class="contact-map-footer">
              In Google Maps öffnen →
            </a>
          </div>

        </div>

        <!-- ÖPNV bar -->
        <div class="contact-oepnv">
          <svg class="contact-oepnv-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="13" rx="2"/><path d="M3 13h18M8 18l-2 3M16 18l2 3M12 16v2"/><circle cx="7.5" cy="16.5" r="0.5" fill="currentColor"/><circle cx="16.5" cy="16.5" r="0.5" fill="currentColor"/>
          </svg>
          <div class="contact-oepnv-text">
            <p class="contact-oepnv-title">Öffentliche Anbindung</p>
            <p class="contact-oepnv-detail">Straßenbahn Linie 042 · Bus Linie 058 · Haltestelle: Neukirchener Straße</p>
          </div>
          <a href="https://maps.google.com/?q=Neukirchener+Straße+5,+47829+Krefeld&travelmode=transit"
             target="_blank" rel="noopener noreferrer" class="contact-oepnv-link">
            Route planen →
          </a>
        </div>

      </div>
    </section>

  </main>

  <footer>
    <div class="footer-inner">
      <p class="footer-copy">© 2026 Praxis van Dinther</p>
      <ul class="footer-links">
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
      </ul>
    </div>
  </footer>

  <script>
    /* ── Canvas organic background ─────────────────────────────── */
    (function () {
      const canvas = document.getElementById('hero-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let t = 0;
      let raf;
      let W, H;

      function resize() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        W = canvas.offsetWidth;
        H = canvas.offsetHeight;
        canvas.width  = W * dpr;
        canvas.height = H * dpr;
        ctx.scale(dpr, dpr);
      }

      function blob(cx, cy, rx, ry, nPts, phase, spd) {
        const pts = [];
        for (let i = 0; i < nPts; i++) {
          const a = (i / nPts) * Math.PI * 2;
          const n1 = Math.sin(a * 2 + t * spd + phase)       * 0.31;
          const n2 = Math.cos(a * 3 + t * spd * 0.65 + phase * 1.4) * 0.18;
          const n3 = Math.sin(a * 7 + t * spd * 0.28)        * 0.07;
          const noise = n1 + n2 + n3;
          pts.push({
            x: cx + Math.cos(a) * rx * (1 + noise),
            y: cy + Math.sin(a) * ry * (1 + noise),
          });
        }
        const l = pts.length;
        ctx.beginPath();
        ctx.moveTo((pts[l-1].x + pts[0].x) / 2, (pts[l-1].y + pts[0].y) / 2);
        for (let i = 0; i < l; i++) {
          const p = pts[i], q = pts[(i + 1) % l];
          ctx.quadraticCurveTo(p.x, p.y, (p.x + q.x) / 2, (p.y + q.y) / 2);
        }
        ctx.closePath();
      }

      function radGrad(cx, cy, r, c0, c1) {
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, c0);
        g.addColorStop(1, c1);
        return g;
      }

      function frame() {
        ctx.fillStyle = '#0d1a10';
        ctx.fillRect(0, 0, W, H);

        ctx.globalCompositeOperation = 'screen';

        /* blob 1 — large deep forest pool, left-centre */
        ctx.globalAlpha = 0.65;
        blob(W * 0.22, H * 0.52, W * 0.44, H * 0.52, 14, 0.0, 0.12);
        ctx.fillStyle = radGrad(W*0.22, H*0.52, W*0.44, '#2e6842', '#091a0e');
        ctx.fill();

        /* blob 2 — medium green, right-centre */
        ctx.globalAlpha = 0.55;
        blob(W * 0.74, H * 0.42, W * 0.36, H * 0.44, 12, 2.1, 0.17);
        ctx.fillStyle = radGrad(W*0.74, H*0.42, W*0.36, '#245238', '#061510');
        ctx.fill();

        /* blob 3 — warm mid-green, bottom */
        ctx.globalAlpha = 0.45;
        blob(W * 0.5, H * 0.82, W * 0.3, H * 0.32, 10, 4.4, 0.22);
        ctx.fillStyle = radGrad(W*0.5, H*0.82, W*0.3, '#3a7a52', '#0a1e12');
        ctx.fill();

        /* blob 4 — amber/gold accent, top-right */
        ctx.globalAlpha = 0.35;
        blob(W * 0.68, H * 0.2, W * 0.22, H * 0.26, 10, 1.0, 0.14);
        ctx.fillStyle = radGrad(W*0.68, H*0.2, W*0.22, '#c8a050', '#3a2408');
        ctx.fill();

        /* blob 5 — very dark green mass, top-left */
        ctx.globalAlpha = 0.40;
        blob(W * 0.12, H * 0.18, W * 0.28, H * 0.3, 10, 3.2, 0.1);
        ctx.fillStyle = radGrad(W*0.12, H*0.18, W*0.28, '#1a4028', '#060f09');
        ctx.fill();

        /* blob 6 — warm amber/gold, centre-left, hsl(35,60%,25%) */
        ctx.globalAlpha = 0.28;
        blob(W * 0.35, H * 0.65, W * 0.26, H * 0.30, 11, 5.5, 0.09);
        ctx.fillStyle = radGrad(W*0.35, H*0.65, W*0.26, 'hsl(35,60%,30%)', 'hsl(35,60%,8%)');
        ctx.fill();

        ctx.globalCompositeOperation = 'source-over';
        ctx.globalAlpha = 1;

        t += 0.004;
        raf = requestAnimationFrame(frame);
      }

      window.addEventListener('resize', resize);
      resize();
      frame();

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(raf);
        else { t += 0; frame(); }
      });
    })();

    /* ── Nav scroll state ───────────────────────────────────────── */
    (function () {
      const nav    = document.getElementById('nav');
      const hero   = document.querySelector('.hero');
      if (!nav || !hero) return;
      function check() {
        const threshold = hero.offsetHeight - 80;
        nav.classList.toggle('scrolled', window.scrollY > threshold);
      }
      window.addEventListener('scroll', check, { passive: true });
      check();
    })();

    /* ── Mobile burger ──────────────────────────────────────────── */
    (function () {
      const burger    = document.getElementById('burger');
      const mobileNav = document.getElementById('mobile-nav');
      if (!burger || !mobileNav) return;

      burger.addEventListener('click', () => {
        const open = burger.getAttribute('aria-expanded') === 'true';
        burger.setAttribute('aria-expanded', String(!open));
        mobileNav.classList.toggle('open', !open);
        document.body.style.overflow = open ? '' : 'hidden';
      });

      mobileNav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          burger.setAttribute('aria-expanded', 'false');
          mobileNav.classList.remove('open');
          document.body.style.overflow = '';
        });
      });
    })();

    /* ── Accordion ──────────────────────────────────────────────── */
    (function () {
      document.querySelectorAll('.accordion-trigger').forEach(trigger => {
        trigger.addEventListener('click', () => {
          const expanded = trigger.getAttribute('aria-expanded') === 'true';
          const bodyId   = trigger.getAttribute('aria-controls');
          const body     = document.getElementById(bodyId);

          document.querySelectorAll('.accordion-trigger').forEach(t => {
            if (t !== trigger) {
              t.setAttribute('aria-expanded', 'false');
              const bid = t.getAttribute('aria-controls');
              document.getElementById(bid)?.classList.remove('open');
            }
          });

          trigger.setAttribute('aria-expanded', String(!expanded));
          body?.classList.toggle('open', !expanded);
        });
      });
    })();

    /* ── Cards headline scroll reveal ──────────────────────────── */
    (function () {
      const headline = document.querySelector('.cards-headline');
      if (!headline) return;
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('visible');
          obs.unobserve(entry.target);
        });
      }, { threshold: 0.2 });
      obs.observe(headline);
    })();

    /* ── Live hours indicator ───────────────────────────────────── */
    (function () {
      const now = new Date();
      const day = now.getDay();
      const mins = now.getHours() * 60 + now.getMinutes();
      const isWeekday = day >= 1 && day <= 5;
      const isMTuTh = [1,2,4].includes(day);
      const hours = {
        termin: isWeekday && ((mins >= 510 && mins < 600) ||
                (isMTuTh && mins >= 960 && mins < 1020)),
        offen:  isWeekday && ((mins >= 600 && mins < 660) ||
                (isMTuTh && mins >= 1020 && mins < 1080)),
        infekt: day >= 1 && day <= 4 && mins >= 660 && mins < 720
      };
      document.querySelectorAll('.hours-card').forEach((card, i) => {
        const key = ['termin','offen','infekt'][i];
        const dot   = card.querySelector('.live-dot');
        const label = card.querySelector('.live-label');
        if (!dot || !label) return;
        if (hours[key]) {
          dot.style.background  = '#22C55E';
          label.textContent     = 'Jetzt geöffnet';
          label.style.color     = '#22C55E';
        } else {
          dot.style.background  = '#ccc';
          label.textContent     = 'Aktuell geschlossen';
          label.style.color     = '#999';
        }
      });
    })();

    /* ── Feature cards: blur-to-sharp reveal ───────────────────── */
    window.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.feature-card');
      cards.forEach((card, i) => {
        card.style.opacity   = '0';
        card.style.filter    = 'blur(16px)';
        card.style.transform = 'translateY(32px)';
        card.style.willChange = 'transform, opacity, filter';
        card.style.transition = `opacity 800ms cubic-bezier(0.16,1,0.3,1) ${i*150}ms,
          filter 800ms cubic-bezier(0.16,1,0.3,1) ${i*150}ms,
          transform 800ms cubic-bezier(0.16,1,0.3,1) ${i*150}ms`;
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity   = '1';
            entry.target.style.filter    = 'blur(0)';
            entry.target.style.transform = 'translateY(0)';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

      cards.forEach(card => observer.observe(card));
    });
  </script>
</body>
</html>
